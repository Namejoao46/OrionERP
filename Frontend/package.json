{
  "name": "orion-ui",
  "version": "0.0.0",
  "main": "src/electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --base-href ./",
    "watch": "ng build --watch --configuration development --base-href ./",
    "test": "ng test",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run start\" \"wait-on http://localhost:4200 && cross-env NODE_ENV=development npm run electron\""
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.8",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "concurrently": "^9.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "wait-on": "^9.0.4",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@types/jasmine": "~5.1.0",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-reload": "^2.0.0-alpha.1",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
