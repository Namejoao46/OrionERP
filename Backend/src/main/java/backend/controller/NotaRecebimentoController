package backend.controller;

import backend.model.Fornecedor;
import backend.service.FornecedorXmlService;
import backend.repository.FornecedorRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

import java.util.Optional;

@RestController
@RequestMapping("/api/notas-recebimento")
@CrossOrigin(origins = "*")
public class NotaRecebimentoController {

    @Autowired
    private FornecedorXmlService xmlService;

    @Autowired
    private FornecedorRepository fornecedorRepository;

    @PostMapping("/upload-xml")
    public ResponseEntity<?> receberNotaXml(@RequestParam("file") MultipartFile file) {
        try {
            if (file.isEmpty()) {
                return ResponseEntity.badRequest().body("Arquivo XML não enviado.");
            }

            Fornecedor fornecedorXml = xmlService.lerDadosEmitente(file.getInputStream());

            Optional<Fornecedor> fornecedorExistente = fornecedorRepository.findByCnpj(fornecedorXml.getCnpj());
            
            Fornecedor fornecedorFinal;
            
            if (fornecedorExistente.isPresent()) {
                fornecedorFinal = fornecedorExistente.get();
                fornecedorFinal.setRazaoSocial(fornecedorXml.getRazaoSocial());
                fornecedorFinal.setNomeFantasia(fornecedorXml.getNomeFantasia());
                fornecedorFinal.setLogradouro(fornecedorXml.getLogradouro());
                fornecedorFinal.setNumero(fornecedorXml.getNumero());
                fornecedorFinal.setBairro(fornecedorXml.getBairro());
                fornecedorFinal.setCidade(fornecedorXml.getCidade());
                fornecedorFinal.setUf(fornecedorXml.getUf());
                fornecedorFinal.setCep(fornecedorXml.getCep());
                
                fornecedorRepository.save(fornecedorFinal);
            } else {
                fornecedorFinal = fornecedorRepository.save(fornecedorXml);
            }

            return ResponseEntity.ok(fornecedorFinal);

        } catch (Exception e) {
            return ResponseEntity.badRequest().body("Erro ao processar XML: " + e.getMessage());
        }
    }
}